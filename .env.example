# ══════════════════════════════════════════════════════════════════
# Ethiopian Payment Verifier Bot — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Your bot's Telegram username WITHOUT the @ (e.g. myverifybot)
BOT_USERNAME=your_bot_username_here

# API key for the payment verification service
VERIFIER_API_KEY=your_api_key_here

# ── Optional ──────────────────────────────────────────────────────
VERIFIER_API_BASE=https://verifyapi.leulzenebe.pro
DATABASE_PATH=bot.db
STORAGE_FILE=paid_channels.json

# Telegram user/chat ID to receive error alerts (leave blank to disable)
ADMIN_ALERT_CHAT_ID=

# ── Business Logic ────────────────────────────────────────────────
# How close the payment amount can be to the required amount (percentage)
AMOUNT_TOLERANCE_PCT=2

# Maximum age of a transaction in hours before it is rejected
TXN_MAX_AGE_HOURS=24

# How long invite links stay valid after being generated (hours)
INVITE_LINK_EXPIRY_HOURS=1

# Maximum number of channels one admin can register
MAX_CHANNELS_PER_ADMIN=10

# ── Scheduler ─────────────────────────────────────────────────────
# How often to check for expiring subscriptions and send warnings
WARNING_CHECK_INTERVAL_HOURS=6

# How often to kick members whose subscriptions have expired
KICK_CHECK_INTERVAL_HOURS=1
